{
  "name": "@halfhalf/server",
  "version": "0.1.0",
  "private": true,
  "description": "HalfHalf 后端服务 — Markdown 自动分页排版引擎",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "express": "^4.21.0",
    "markdown-it": "^14.1.0",
    "markdown-it-katex": "^2.0.3",
    "handlebars": "^4.7.8",
    "pdf-lib": "^1.17.1",
    "cors": "^2.8.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/markdown-it": "^14.1.2",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^10.0.0",
    "playwright": "^1.45.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}